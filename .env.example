# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bpa_db

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Bcrypt ─────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Email Gateway ──────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=no-reply@example.com
EMAIL_PASS=email_password
EMAIL_FROM="Bangladesh Pet Association <no-reply@example.com>"

# ─── SMS Gateway ────────────────────────────────────────────────
SMS_API_URL=https://sms-gateway.example.com/api/send
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=BPA

# ─── EPS Payment ────────────────────────────────────────────────
EPS_API_URL=https://api.eps-gateway.com
EPS_MERCHANT_ID=your_merchant_id
EPS_SECRET_KEY=your_eps_secret_key
EPS_WEBHOOK_SECRET=your_webhook_secret

# ─── Media / File Storage ────────────────────────────────────────
# STORAGE_DRIVER=local  → write files to ./uploads/ (default for development)
# STORAGE_DRIVER=s3     → upload to S3-compatible provider (MinIO, AWS, DO Spaces, etc.)
STORAGE_DRIVER=local

# Required when STORAGE_DRIVER=s3
# MinIO (local dev):
#   S3_ENDPOINT=http://127.0.0.1:9000
#   S3_FORCE_PATH_STYLE=true
# AWS S3 (production):
#   S3_ENDPOINT=   (leave blank — SDK auto-resolves)
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=bpa-media
S3_ACCESS_KEY_ID=your_minio_access_key
S3_SECRET_ACCESS_KEY=your_minio_secret_key
S3_FORCE_PATH_STYLE=true

# Public base URL used when building media URLs returned to clients.
# MinIO (local):  http://127.0.0.1:9000/bpa-media
# AWS S3:         https://bpa-media.s3.amazonaws.com
# DO Spaces:      https://bpa-media.nyc3.digitaloceanspaces.com
# Leave unset when STORAGE_DRIVER=local — falls back to BACKEND_URL/uploads
MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:9000/bpa-media
