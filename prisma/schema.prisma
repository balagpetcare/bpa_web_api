// ─── Location Hierarchy ────────────────────────────────────────────

model Country {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(120)
  code      String   @unique @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  divisions Division[]

  @@map("countries")
}

model Division {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(120)
  countryId String   @map("country_id") @db.Uuid
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  country   Country    @relation(fields: [countryId], references: [id])
  districts District[]

  @@unique([name, countryId])
  @@index([countryId])
  @@map("divisions")
}

model District {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(120)
  divisionId String   @map("division_id") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  division         Division          @relation(fields: [divisionId], references: [id])
  cityCorporations CityCorporation[]

  @@unique([name, divisionId])
  @@index([divisionId])
  @@map("districts")
}

model CityCorporation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(120)
  districtId String   @map("district_id") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  district District @relation(fields: [districtId], references: [id])
  zones    Zone[]

  @@unique([name, districtId])
  @@index([districtId])
  @@map("city_corporations")
}

model Zone {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String   @db.VarChar(120)
  cityCorporationId String   @map("city_corporation_id") @db.Uuid
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  cityCorporation        CityCorporation         @relation(fields: [cityCorporationId], references: [id])
  venues                 Venue[]
  volunteerCoverageAreas VolunteerCoverageArea[]

  @@unique([name, cityCorporationId])
  @@index([cityCorporationId])
  @@map("zones")
}

model Venue {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(255)
  address       String   @db.Text
  googleMapsUrl String?  @map("google_maps_url") @db.Text
  latitude      Decimal? @db.Decimal(9, 6)
  longitude     Decimal? @db.Decimal(9, 6)
  zoneId        String   @map("zone_id") @db.Uuid
  // Optional location tree references
  divisionId    String?  @map("division_id") @db.Uuid
  districtId    String?  @map("district_id") @db.Uuid
  upazilaId     String?  @map("upazila_id") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  zone             Zone              @relation(fields: [zoneId], references: [id])
  campaignSessions CampaignSession[]

  @@unique([name, zoneId])
  @@index([zoneId])
  @@index([name])
  @@map("venues")
}

// ─── Unified Location Tree ─────────────────────────────────────────
// Replaces flat Country→Division→District→CityCorporation hierarchy with
// a self-referential tree supporting all BD administrative levels + wards.

model Location {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parentId   String?      @map("parent_id") @db.Uuid
  type       LocationType
  nameEn     String       @map("name_en") @db.VarChar(255)
  nameBn     String?      @map("name_bn") @db.VarChar(255)
  slug       String       @db.VarChar(255)
  code       String?      @db.VarChar(50)
  source     String?      @db.VarChar(100)
  sourceId   String?      @map("source_id") @db.VarChar(100)
  lat        Decimal?     @db.Decimal(10, 7)
  lon        Decimal?     @db.Decimal(10, 7)
  isActive   Boolean      @default(true) @map("is_active")
  isVerified Boolean      @default(true) @map("is_verified")
  sortOrder  Int          @default(0) @map("sort_order")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  parent   Location?  @relation("LocationTree", fields: [parentId], references: [id])
  children Location[] @relation("LocationTree")

  @@index([type])
  @@index([parentId])
  @@index([source, sourceId])
  @@map("location_nodes")
}

