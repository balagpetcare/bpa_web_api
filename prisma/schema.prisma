  module           String?   @db.VarChar(60)
  entityType       String?   @map("entity_type") @db.VarChar(60)
  entityId         String?   @map("entity_id") @db.Uuid
  reference        String?   @db.VarChar(120)
  status           SmsStatus @default(queued)
  provider         String    @db.VarChar(60)
  providerRef      String?   @map("provider_ref") @db.VarChar(255)
  failureReason    String?   @map("failure_reason") @db.VarChar(60)
  failureDetail    String?   @map("failure_detail") @db.Text
  payload          Json?
  attemptCount     Int       @default(0) @map("attempt_count")
  maxAttempts      Int       @default(3) @map("max_attempts")
  lastAttemptAt    DateTime? @map("last_attempt_at") @db.Timestamptz
