generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────

enum NewsStatus {
  draft
  published
  archived
}

enum EventStatus {
  draft
  published
  cancelled
}

enum RegistrationStatus {
  pending
  confirmed
  cancelled
}

enum VolunteerStatus {
  pending
  approved
  rejected
}

enum MembershipType {
  individual
  family
  corporate
}

enum MembershipStatus {
  active
  expired
  cancelled
}

enum PaymentGateway {
  eps
}

enum PaymentStatus {
  pending
  success
  failed
  cancelled
  pending_review
  refunded
}

enum ContactStatus {
  unread
  read
  replied
}

enum SmsStatus {
  queued
  sending
  sent
  delivered
  failed
  undelivered
  cancelled
  skipped
}

enum EmailStatus {
  queued
  sent
  delivered
  failed
  bounced
  spam
}

enum AuditAction {
  create
  update
  delete
  publish
  unpublish
  approve
  reject
  upload
}

enum AuthProvider {
  GOOGLE
  FACEBOOK
  INSTAGRAM
  TWITTER
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum OtpPurpose {
  LOGIN
  REGISTER
  RESET_PASSWORD
}

enum HomepageStatus {
  draft
  published
  archived
}

enum HomepageSectionType {
  hero
  stats
  mission
  campaigns
  news
  events
  vision
  committee
  cta
  partners
  custom
  community_pet_care
  zone_progress
  pet_census
  transparency
  pet_smart_solution
}

enum HomepageSectionSource {
  manual
  automatic
  static
}

enum HeroSlideStatus {
  draft
  published
  archived
}

enum HeroSlideMediaType {
  image
  video
}

enum HeroSlideOverlayPosition {
  left
  center
  right
}

enum HomepageCtaType {
  none
  internal
  external
}

enum CampaignRegistrationStatus {
  pending_payment
  paid
  checked_in
  vaccinated
  certificate_issued
  completed
  no_show
  cancelled
}

enum WaitlistStatus {
  waiting
  promoted
  expired
  cancelled
}

// ─── Community Pet Care Enums ────────────────────────────────────

enum CommunityZoneStatus {
  active
  inactive
  coming_soon
}

enum ZoneClinicStatus {
  planned
  priority
  in_progress
  active
  paused
}

enum ContributionType {
  care_partner
}

enum ContributionStatus {
  pending_payment
  paid
  refunded
  cancelled
}

enum CarePartnerCardStatus {
  pending
  active
  expired
  revoked
}

enum PetCensusStatus {
  new
  contacted
  converted
  submitted
  verified
  duplicate
  archived
}

enum LocationType {
  DIVISION
  DISTRICT
  UPAZILA
  THANA
  UNION
  POURASHAVA
  CITY_CORPORATION
  CITY_ZONE
  WARD
  AREA
}

enum TransparencyReportStatus {
  draft
  published
  archived
}

enum PetSmartSyncStatus {
  pending
  success
  failed
  skipped
}

// ─── Identity & Auth ────────────────────────────────────────────

model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String     @db.VarChar(120)
  email               String?    @unique @db.VarChar(255)
  passwordHash        String?    @map("password_hash") @db.Text
  phone               String?    @unique @db.VarChar(20)
  avatarUrl           String?    @map("avatar_url") @db.Text
  role                String     @default("USER") @db.VarChar(20)
  status              UserStatus @default(ACTIVE)
  emailVerifiedAt     DateTime?  @map("email_verified_at") @db.Timestamptz
  phoneVerifiedAt     DateTime?  @map("phone_verified_at") @db.Timestamptz
  isActive            Boolean    @default(true) @map("is_active")
  failedLoginAttempts Int        @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime?  @map("locked_until") @db.Timestamptz
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz

  // Location tree references (nullable, for address/profile)
  divisionId        String?  @map("division_id") @db.Uuid
  districtId        String?  @map("district_id") @db.Uuid
  upazilaId         String?  @map("upazila_id") @db.Uuid
  unionId           String?  @map("union_id") @db.Uuid
  cityCorporationId String?  @map("city_corporation_id") @db.Uuid
  cityZoneId        String?  @map("city_zone_id") @db.Uuid
  wardId            String?  @map("ward_id") @db.Uuid
  addressLine       String?  @map("address_line") @db.Text

  userRoles              UserRole[]
  authAccounts           AuthAccount[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  news                   News[]
  mediaFiles             MediaFile[]
  volunteersReviewed     Volunteer[]             @relation("ReviewedBy")
  contactsReplied        ContactSubmission[]     @relation("RepliedBy")
  seoUpdates             SeoMetadata[]
  refreshTokens          RefreshToken[]
  members                Member[]
  campaignsCreated       Campaign[]              @relation("CampaignCreatedBy")
  doctorProfile          Doctor?
  campaignVolunteers     CampaignVolunteer[]
  petOwners              PetOwner[]
  volunteerCoverageAreas VolunteerCoverageArea[]
  qrScanLogs             QRScanLog[]
  certificatesIssued     Certificate[]           @relation("CertificateIssuedBy")
  homepageUpdates        Homepage[]              @relation("HomepageUpdatedBy")
  censusSubmissions      PetCensusSubmission[]
  donations              Donation[]

  @@map("users")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(60)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource  String   @db.VarChar(80)
  action    String   @db.VarChar(40)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model AuthAccount {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id") @db.VarChar(255)
  providerEmail     String?      @map("provider_email") @db.VarChar(255)
  accessToken       String?      @map("access_token") @db.Text
  refreshToken      String?      @map("refresh_token") @db.Text
  expiresAt         DateTime?    @map("expires_at") @db.Timestamptz
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model OtpCode {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone      String     @db.VarChar(20)
  otpHash    String     @map("otp_hash") @db.Text
  purpose    OtpPurpose @default(LOGIN)
  expiresAt  DateTime   @map("expires_at") @db.Timestamptz
  consumedAt DateTime?  @map("consumed_at") @db.Timestamptz
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone, purpose])
  @@map("otp_codes")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.Text
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") @db.Text
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.Text
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Audit ──────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  actorEmail String?     @map("actor_email") @db.VarChar(255)
  action     AuditAction
  resource   String      @db.VarChar(80)
  resourceId String?     @map("resource_id") @db.VarChar(255)
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.VarChar(45)
  userAgent  String?     @map("user_agent") @db.Text
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@index([resource, resourceId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── News CMS ───────────────────────────────────────────────────

model NewsCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  news News[]

  @@map("news_categories")
}

model NewsTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(80)
  slug      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  news News[]

  @@map("news_tags")
}

model News {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String     @db.VarChar(255)
  slug         String     @unique @db.VarChar(280)
  excerpt      String?    @db.Text
  body         String     @db.Text
  coverImageId String?    @map("cover_image_id") @db.Uuid
  authorId     String     @map("author_id") @db.Uuid
  categoryId   String?    @map("category_id") @db.Uuid
  status       NewsStatus @default(draft)
  isFeatured   Boolean    @default(false) @map("is_featured")
  publishedAt  DateTime?  @map("published_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  author     User          @relation(fields: [authorId], references: [id])
  coverImage MediaFile?    @relation("NewsCover", fields: [coverImageId], references: [id])
  category   NewsCategory? @relation(fields: [categoryId], references: [id])
  tags       NewsTag[]

  @@index([status, publishedAt])
  @@index([slug])
  @@map("news")
}

// ─── Events ─────────────────────────────────────────────────────

model Event {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String      @db.VarChar(255)
  slug         String      @unique @db.VarChar(280)
  description  String?     @db.Text
  coverImageId String?     @map("cover_image_id") @db.Uuid
  location     String?     @db.VarChar(255)
  startsAt     DateTime    @map("starts_at") @db.Timestamptz
  endsAt       DateTime?   @map("ends_at") @db.Timestamptz
  capacity     Int?
  isPaid       Boolean     @default(false) @map("is_paid")
  fee          Decimal?    @db.Decimal(10, 2)
  status       EventStatus @default(draft)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  coverImage    MediaFile?          @relation("EventCover", fields: [coverImageId], references: [id])
  registrations EventRegistration[]

  @@index([status, startsAt])
  @@map("events")
}

model EventRegistration {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String             @map("event_id") @db.Uuid
  userId    String?            @map("user_id") @db.Uuid
  name      String             @db.VarChar(120)
  email     String             @db.VarChar(255)
  phone     String?            @db.VarChar(20)
  paymentId String?            @map("payment_id") @db.Uuid
  status    RegistrationStatus @default(pending)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz

  event   Event    @relation(fields: [eventId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("event_registrations")
}

// ─── Committee ──────────────────────────────────────────────────

model CommitteeMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(120)
  designation String   @db.VarChar(120)
  bio         String?  @db.Text
  photoId     String?  @map("photo_id") @db.Uuid
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  photo MediaFile? @relation("CommitteePhoto", fields: [photoId], references: [id])

  @@index([sortOrder, isActive])
  @@map("committee_members")
}

// ─── Community ──────────────────────────────────────────────────

model Volunteer {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @db.VarChar(120)
  email          String          @db.VarChar(255)
  phone          String?         @db.VarChar(20)
  areaOfInterest String?         @map("area_of_interest") @db.Text
  availability   String?         @db.Text
  message        String?         @db.Text
  status         VolunteerStatus @default(pending)
  reviewedById   String?         @map("reviewed_by") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  reviewedBy User? @relation("ReviewedBy", fields: [reviewedById], references: [id])

  @@map("volunteers")
}

model Member {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  membershipType MembershipType @map("membership_type")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id])
  memberships Membership[]

  @@map("members")
}

model Membership {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId  String           @map("member_id") @db.Uuid
  paymentId String?          @map("payment_id") @db.Uuid
  startsAt  DateTime         @map("starts_at") @db.Date
  expiresAt DateTime         @map("expires_at") @db.Date
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  member  Member   @relation(fields: [memberId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("memberships")
}

// ─── Payments ───────────────────────────────────────────────────

model Payment {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gateway       PaymentGateway
  gatewayRef    String?        @map("gateway_ref") @db.VarChar(255)
  merchantTxnId String?        @unique @map("merchant_txn_id") @db.VarChar(40)
  epsTxnId      String?        @map("eps_txn_id") @db.VarChar(255)
  amount        Decimal        @db.Decimal(10, 2)
  currency      String         @default("BDT") @db.VarChar(3)
  status        PaymentStatus  @default(pending)
  purpose       String         @default("general") @db.VarChar(60)
  payload       Json?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  memberships           Membership[]
  eventRegistrations    EventRegistration[]
  campaignRegistrations CampaignRegistration[]
  careContributions     CareContribution[]
  entityType            String?                @map("entity_type") @db.VarChar(30)
  entityId              String?                @map("entity_id") @db.Uuid

  communityMembershipPurchase CommunityMembershipPurchase? @relation("PurchasePayment")
  communityMembershipUpgrades CommunityMembershipUpgrade[] @relation("UpgradePayment")
  donations                   Donation[]

  @@index([entityType, entityId])
  @@map("payments")
}

// ─── Contacts ───────────────────────────────────────────────────

model ContactSubmission {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String        @db.VarChar(120)
  email       String        @db.VarChar(255)
  phone       String?       @db.VarChar(20)
  subject     String?       @db.VarChar(255)
  message     String        @db.Text
  status      ContactStatus @default(unread)
  repliedById String?       @map("replied_by") @db.Uuid
  repliedAt   DateTime?     @map("replied_at") @db.Timestamptz
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  repliedBy User? @relation("RepliedBy", fields: [repliedById], references: [id])

  @@map("contact_submissions")
}

// ─── Media ──────────────────────────────────────────────────────

model MediaFile {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename     String   @db.VarChar(255)
  originalName String   @map("original_name") @db.VarChar(255)
  mimeType     String   @map("mime_type") @db.VarChar(100)
  sizeBytes    BigInt   @map("size_bytes")
  url          String   @db.Text
  altText      String?  @map("alt_text") @db.VarChar(255)
  uploadedById String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  uploadedBy               User?                 @relation(fields: [uploadedById], references: [id])
  newsCovers               News[]                @relation("NewsCover")
  eventCovers              Event[]               @relation("EventCover")
  committeePhotos          CommitteeMember[]     @relation("CommitteePhoto")
  seoImages                SeoMetadata[]
  petPhotos                Pet[]                 @relation("PetPhoto")
  campaignCovers           Campaign[]            @relation("CampaignCover")
  campaignMediaItems       CampaignMedia[]
  homepageSectionItems     HomepageSectionItem[] @relation("HomepageSectionItemMedia")
  heroDesktopImages        HeroSlide[]           @relation("HeroDesktopImage")
  heroMobileImages         HeroSlide[]           @relation("HeroMobileImage")
  heroVideos               HeroSlide[]           @relation("HeroVideo")
  partnerLogos             Partner[]             @relation("PartnerLogo")
  footerLogos              FooterConfig[]        @relation("FooterLogo")
  communityZoneCovers      CommunityZone[]       @relation("CommunityZoneCover")
  transparencyReportCovers TransparencyReport[]  @relation("TransparencyReportCover")
  petCensusPhotos          PetCensusSubmission[]

  @@index([mimeType])
  @@map("media_files")
}

// ─── SEO ────────────────────────────────────────────────────────

model SeoMetadata {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  route         String   @unique @db.VarChar(255)
  title         String?  @db.VarChar(255)
  description   String?  @db.Text
  ogTitle       String?  @map("og_title") @db.VarChar(255)
  ogDescription String?  @map("og_description") @db.Text
  ogImageId     String?  @map("og_image_id") @db.Uuid
  schemaJson    Json?    @map("schema_json")
  updatedById   String?  @map("updated_by") @db.Uuid
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  ogImage   MediaFile? @relation(fields: [ogImageId], references: [id])
  updatedBy User?      @relation(fields: [updatedById], references: [id])

  @@map("seo_metadata")
}

// â”€â”€â”€ Homepage CMS â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model Homepage {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locale      String         @default("en") @db.VarChar(10)
  title       String?        @db.VarChar(255)
  description String?        @db.Text
  status      HomepageStatus @default(draft)
  settings    Json?
  publishedAt DateTime?      @map("published_at") @db.Timestamptz
  updatedById String?        @map("updated_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  updatedBy User?             @relation("HomepageUpdatedBy", fields: [updatedById], references: [id])
  sections  HomepageSection[]

  @@unique([locale])
  @@index([status])
  @@map("homepages")
}

model HomepageSection {
  id         String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  homepageId String                @map("homepage_id") @db.Uuid
  type       HomepageSectionType
  source     HomepageSectionSource @default(static)
  title      String?               @db.VarChar(255)
  eyebrow    String?               @db.VarChar(120)
  subtitle   String?               @db.Text
  body       String?               @db.Text
  ctaType    HomepageCtaType       @default(none) @map("cta_type")
  ctaLabel   String?               @map("cta_label") @db.VarChar(80)
  ctaHref    String?               @map("cta_href") @db.Text
  ctaTarget  String                @default("_self") @map("cta_target") @db.VarChar(20)
