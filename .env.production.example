# ─────────────────────────────────────────────────────────────────────────────
# BPA Backend API — Production Environment Variables
# Copy to .env on the production server. Never commit the filled-in file.
#
# Generate secrets:
#   openssl rand -hex 32      → 64-char hex string (JWT secrets, QR secrets)
#   openssl rand -base64 32   → 44-char base64 string (NEXTAUTH_SECRET style)
#
# Startup order:
#   1. Fill every blank value below.
#   2. npm run db:migrate:prod
#   3. npm run db:seed
#   4. npm start   (or PM2 / Docker — see PRODUCTION_DEPLOYMENT_CHECKLIST.md)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.bangladeshpetassociation.com
BACKEND_URL=https://api.bangladeshpetassociation.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
DATABASE_URL=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Minimum 32 chars. Use: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Auth / Social Login ─────────────────────────────────────────────────────
# Same minimum 32 chars as JWT secrets.
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=bpa_user_session
AUTH_PUBLIC_WEB_URL=https://bangladeshpetassociation.com
AUTH_ADMIN_WEB_URL=https://admin.bangladeshpetassociation.com
AUTH_API_URL=https://api.bangladeshpetassociation.com

# OAuth (leave blank to disable each provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/facebook/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/instagram/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/twitter/callback

# ─── QR / HMAC Secrets ───────────────────────────────────────────────────────
# REQUIRED in production — the app will refuse to start with the default values.
# Use: openssl rand -hex 32
QR_SECRET=
CARE_CARD_QR_SECRET=

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://bangladeshpetassociation.com,https://admin.bangladeshpetassociation.com
FRONTEND_URL=https://bangladeshpetassociation.com
PUBLIC_WEB_URL=https://bangladeshpetassociation.com
ADMIN_BASE_URL=https://admin.bangladeshpetassociation.com

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Seed Admin ──────────────────────────────────────────────────────────────
# Used once by: npm run db:seed — creates the super_admin account.
# After initial seed, remove or rotate SEED_ADMIN_PASSWORD.
SEED_ADMIN_NAME=BPA Super Admin
SEED_ADMIN_EMAIL=admin@bangladeshpetassociation.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_ROLE=super_admin

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5

# ─── Mailing System ──────────────────────────────────────────────────────────
# MAIL_CREDENTIAL_SECRET: AES-256 key used to encrypt per-account SMTP passwords
# stored in the DB. Min 32 chars. Use: openssl rand -hex 32
MAIL_CREDENTIAL_SECRET=
DEFAULT_SMTP_HOST=d552.dimedns.com
DEFAULT_SMTP_PORT=465
DEFAULT_SMTP_SECURE=true
DEFAULT_IMAP_HOST=d552.dimedns.com
DEFAULT_IMAP_PORT=993
DEFAULT_IMAP_SECURE=true
MAIL_SYNC_ENABLED=true
MAIL_SYNC_INTERVAL_MINUTES=5
MAIL_ATTACHMENT_MAX_MB=15

# ─── SMS Gateway ─────────────────────────────────────────────────────────────
# Bangladesh SMS providers: SSL Wireless, Infobip, Twilio, etc.
# The service expects POST { to, message } with Bearer auth.
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=BPA

# ─── EPS Payment Gateway ─────────────────────────────────────────────────────
# Obtain production credentials from EPS Bangladesh (https://eps.com.bd).
EPS_ENABLED=true
EPS_ENV=production
PAYMENT_CHANNEL_MODE=EPS
PAYMENT_PROVIDER=EPS
DONATION_PAYMENT_MODE=GATEWAY

# Production EPS endpoint (no trailing slash)
EPS_BASE_URL=https://pgapi.eps.com.bd
EPS_API_BASE_URL=https://pgapi.eps.com.bd

EPS_MERCHANT_ID=
EPS_STORE_ID=
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=

# Callback URLs — must match paths registered with EPS
# Path is /api/v1/payment/callback/{result}  (singular "payment")
EPS_SUCCESS_URL=https://api.bangladeshpetassociation.com/api/v1/payment/callback/success
EPS_FAIL_URL=https://api.bangladeshpetassociation.com/api/v1/payment/callback/fail
EPS_CANCEL_URL=https://api.bangladeshpetassociation.com/api/v1/payment/callback/cancel

# Comma-separated EPS server IPs for callback allowlisting (leave empty to skip)
EPS_CALLBACK_IPS=

# Comma-separated frontend domains allowed as redirect targets after payment
EPS_ALLOWED_REDIRECT_HOSTS=https://bangladeshpetassociation.com

# ─── Manual / MFS Payment (fallback when EPS is not active) ──────────────────
MFS_BKASH_NUMBER=01XXXXXXXXX
MFS_NAGAD_NUMBER=01XXXXXXXXX
MFS_ROCKET_NUMBER=01XXXXXXXXX
MFS_ACCOUNT_HOLDER=Bangladesh Pet Association

# ─── Media / File Storage ────────────────────────────────────────────────────
# In production always use STORAGE_DRIVER=s3.
# Supported providers: AWS S3, Cloudflare R2, Backblaze B2, DigitalOcean Spaces.
STORAGE_DRIVER=s3

# For AWS S3: leave S3_ENDPOINT blank (SDK auto-resolves) and set S3_FORCE_PATH_STYLE=false
# For R2/B2/Spaces: set S3_ENDPOINT to provider endpoint and S3_FORCE_PATH_STYLE=false
# For local MinIO only: S3_ENDPOINT=http://127.0.0.1:9000 S3_FORCE_PATH_STYLE=true
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=bpa-production-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Public URL where uploaded media files are served to clients.
# AWS S3:        https://bpa-production-media.s3.amazonaws.com
# R2 custom:     https://media.bangladeshpetassociation.com
# B2:            https://f005.backblazeb2.com/file/bpa-production-media
MEDIA_PUBLIC_BASE_URL=https://media.bangladeshpetassociation.com

# ─── Analytics (backend-side, optional) ──────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
