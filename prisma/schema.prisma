  postalCode               String?  @map("postal_code") @db.VarChar(20)
  country                  String?  @map("country") @db.VarChar(100)
  mapEmbedUrl              String?  @map("map_embed_url") @db.Text
  mapLink                  String?  @map("map_link") @db.Text
  // ─── Branding ────────────────────────────────────────────────────
  primaryLogoUrl           String?  @map("primary_logo_url") @db.Text
  secondaryLogoUrl         String?  @map("secondary_logo_url") @db.Text
  faviconUrl               String?  @map("favicon_url") @db.Text
  websiteUrl               String?  @map("website_url") @db.VarChar(200)
  legalName                String?  @map("legal_name") @db.VarChar(200)
  defaultMetaTitle         String?  @map("default_meta_title") @db.VarChar(200)
  defaultMetaDescription   String?  @map("default_meta_description") @db.Text
  receiptFooterNote        String?  @map("receipt_footer_note") @db.Text
  donationReceiptTermsBn   String?  @map("donation_receipt_terms_bn") @db.Text
  donationReceiptTermsEn   String?  @map("donation_receipt_terms_en") @db.Text
  // ─── Social ──────────────────────────────────────────────────────
  facebookUrl              String?  @map("facebook_url") @db.Text
  youtubeUrl               String?  @map("youtube_url") @db.Text
  linkedinUrl              String?  @map("linkedin_url") @db.Text
  // ─── Public messages ─────────────────────────────────────────────
  registrationErrorTitle   String   @default("Online registration temporarily unavailable") @map("registration_error_title") @db.VarChar(300)
  registrationErrorMessage String   @default("Online registration/payment is temporarily unavailable. Please call BPA support for assistance.") @map("registration_error_message") @db.Text
  emergencyNotice          String?  @map("emergency_notice") @db.Text
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("site_settings")
}

// ─── Public Donation System ────────────────────────────────────

enum DonationCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum DonorType {
  INDIVIDUAL
  ORGANIZATION
  ANONYMOUS
}

enum DonationImpactStoryType {
  RESCUE
  VACCINATION
  FOOD
  TREATMENT
  ADOPTION
  AWARENESS
}

model DonationPurpose {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titleEn            String   @map("title_en") @db.VarChar(120)
  titleBn            String?  @map("title_bn") @db.VarChar(120)
  slug               String   @unique @db.VarChar(140)
  shortDescriptionEn String?  @map("short_description_en") @db.Text
  shortDescriptionBn String?  @map("short_description_bn") @db.Text
  icon               String?  @db.VarChar(100)
  imageUrl           String?  @map("image_url") @db.Text
  suggestedAmounts   Json?    @map("suggested_amounts")
  impactTextEn       String?  @map("impact_text_en") @db.Text
  impactTextBn       String?  @map("impact_text_bn") @db.Text
  sortOrder          Int      @default(0) @map("sort_order")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  campaigns      DonationCampaign[]
  donations      Donation[]
  impactStories  DonationImpactStory[]
  qrCodes        DonationQrCode[]

  @@index([isActive, sortOrder])
  @@map("donation_purposes")
}

model DonationCampaign {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titleEn           String                 @map("title_en") @db.VarChar(255)
  titleBn           String?                @map("title_bn") @db.VarChar(255)
  slug              String                 @unique @db.VarChar(280)
  descriptionEn     String?                @map("description_en") @db.Text
  descriptionBn     String?                @map("description_bn") @db.Text
  goalAmount        Decimal                @default(0) @map("goal_amount") @db.Decimal(14, 2)
  raisedAmount      Decimal                @default(0) @map("raised_amount") @db.Decimal(14, 2)
  startDate         DateTime?              @map("start_date") @db.Timestamptz
  endDate           DateTime?              @map("end_date") @db.Timestamptz
  featuredImageUrl  String?                @map("featured_image_url") @db.Text
  videoUrl          String?                @map("video_url") @db.Text
  status            DonationCampaignStatus @default(DRAFT)
  showOnDonatePage  Boolean                @default(true) @map("show_on_donate_page")
  allowCustomAmount Boolean                @default(true) @map("allow_custom_amount")
  defaultAmount     Decimal?               @map("default_amount") @db.Decimal(10, 2)
  suggestedAmounts  Json?                  @map("suggested_amounts")
  purposeId         String?                @map("purpose_id") @db.Uuid
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  purpose       DonationPurpose?      @relation(fields: [purposeId], references: [id], onDelete: SetNull)
  donations     Donation[]
  impactStories DonationImpactStory[]
  qrCodes       DonationQrCode[]

  @@index([status, showOnDonatePage])
  @@map("donation_campaigns")
}

model Donation {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceNo           String        @unique @map("reference_no") @db.VarChar(30)
  userId                String?       @map("user_id") @db.Uuid
  donorName             String        @map("donor_name") @db.VarChar(120)
  donorEmail            String?       @map("donor_email") @db.VarChar(255)
  donorPhone            String?       @map("donor_phone") @db.VarChar(20)
  donorCountry          String?       @map("donor_country") @db.VarChar(120)
  donorType             DonorType     @default(INDIVIDUAL) @map("donor_type")
  organizationName      String?       @map("organization_name") @db.VarChar(200)
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("BDT") @db.VarChar(3)
  purposeId             String?       @map("purpose_id") @db.Uuid
  campaignId            String?       @map("campaign_id") @db.Uuid
  source                String?       @db.VarChar(100)
  qrCodeId              String?       @map("qr_code_id") @db.Uuid
  message               String?       @db.Text
  isAnonymous           Boolean       @default(false) @map("is_anonymous")
  showOnDonorWall       Boolean       @default(true) @map("show_on_donor_wall")
  status                PaymentStatus @default(pending)
  paymentProvider       String        @default("EPS") @map("payment_provider") @db.VarChar(30)
  paymentIntentId       String?       @map("payment_intent_id") @db.VarChar(100)
  gatewayTransactionId  String?       @map("gateway_transaction_id") @db.VarChar(100)
  paidAt                DateTime?     @map("paid_at") @db.Timestamptz
  paymentId             String?       @unique @map("payment_id") @db.Uuid
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  purpose  DonationPurpose?  @relation(fields: [purposeId], references: [id], onDelete: SetNull)
  campaign DonationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  qrCode   DonationQrCode?   @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  payment  Payment?          @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([referenceNo])
  @@map("donations")
}

model DonationQrCode {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String   @db.VarChar(120)
  slug          String   @unique @db.VarChar(140)
  purposeId     String?  @map("purpose_id") @db.Uuid
  campaignId    String?  @map("campaign_id") @db.Uuid
  source        String?  @db.VarChar(100)
  location      String?  @db.VarChar(255)
  targetUrl     String   @map("target_url") @db.Text
  qrImageUrl    String?  @map("qr_image_url") @db.Text
  scanCount     Int      @default(0) @map("scan_count")
  donationCount Int      @default(0) @map("donation_count")
  totalRaised   Decimal  @default(0) @map("total_raised") @db.Decimal(14, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  purpose   DonationPurpose?  @relation(fields: [purposeId], references: [id], onDelete: SetNull)
  campaign  DonationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  donations Donation[]

  @@map("donation_qr_codes")
}

model DonationImpactStory {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titleEn            String                  @map("title_en") @db.VarChar(255)
  titleBn            String?                 @map("title_bn") @db.VarChar(255)
  slug               String                  @unique @db.VarChar(280)
  storyType          DonationImpactStoryType @default(RESCUE) @map("story_type")
  location           String?                 @db.VarChar(255)
  animalType         String?                 @map("animal_type") @db.VarChar(100)
  shortDescriptionEn String?                 @map("short_description_en") @db.Text
  shortDescriptionBn String?                 @map("short_description_bn") @db.Text
  fullStoryEn        String                  @map("full_story_en") @db.Text
  fullStoryBn        String?                 @map("full_story_bn") @db.Text
  beforeImageUrl     String?                 @map("before_image_url") @db.Text
  afterImageUrl      String?                 @map("after_image_url") @db.Text
  costUsed           Decimal?                @map("cost_used") @db.Decimal(12, 2)
  purposeId          String?                 @map("purpose_id") @db.Uuid
  campaignId         String?                 @map("campaign_id") @db.Uuid
  storyDate          DateTime?               @map("story_date") @db.Timestamptz
  status             String                  @default("DRAFT") @db.VarChar(20)
  showOnDonationPage Boolean                 @default(true) @map("show_on_donation_page")
  sortOrder          Int                     @default(0) @map("sort_order")
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  purpose  DonationPurpose?  @relation(fields: [purposeId], references: [id], onDelete: SetNull)
  campaign DonationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status, showOnDonationPage, sortOrder])
  @@map("donation_impact_stories")
}

model DonationTransparencyReport {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportMonth                String   @map("report_month") @db.VarChar(7)
  titleEn                    String   @map("title_en") @db.VarChar(255)
  titleBn                    String?  @map("title_bn") @db.VarChar(255)
  totalReceived              Decimal  @default(0) @map("total_received") @db.Decimal(14, 2)
  totalUsed                  Decimal  @default(0) @map("total_used") @db.Decimal(14, 2)
  openingBalance             Decimal  @default(0) @map("opening_balance") @db.Decimal(14, 2)
  closingBalance             Decimal  @default(0) @map("closing_balance") @db.Decimal(14, 2)
  vaccinationExpense         Decimal  @default(0) @map("vaccination_expense") @db.Decimal(12, 2)
  foodExpense                Decimal  @default(0) @map("food_expense") @db.Decimal(12, 2)
  treatmentExpense           Decimal  @default(0) @map("treatment_expense") @db.Decimal(12, 2)
  rescueTransportExpense     Decimal  @default(0) @map("rescue_transport_expense") @db.Decimal(12, 2)
  clinicFundAllocation       Decimal  @default(0) @map("clinic_fund_allocation") @db.Decimal(14, 2)
  adminAndProcessingExpense  Decimal  @default(0) @map("admin_and_processing_expense") @db.Decimal(12, 2)
  pdfUrl                     String?  @map("pdf_url") @db.Text
  status                     String   @default("DRAFT") @db.VarChar(20)
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("donation_transparency_reports")
}

model DonationPageSetting {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  heroTitleEn          String   @map("hero_title_en") @db.VarChar(255)
  heroTitleBn          String?  @map("hero_title_bn") @db.VarChar(255)
  heroSubtitleEn       String?  @map("hero_subtitle_en") @db.Text
  heroSubtitleBn       String?  @map("hero_subtitle_bn") @db.Text
  heroImageUrl         String?  @map("hero_image_url") @db.Text
  heroVideoUrl         String?  @map("hero_video_url") @db.Text
  primaryCtaTextEn     String?  @map("primary_cta_text_en") @db.VarChar(100)
  primaryCtaTextBn     String?  @map("primary_cta_text_bn") @db.VarChar(100)
  secondaryCtaTextEn   String?  @map("secondary_cta_text_en") @db.VarChar(100)
  secondaryCtaTextBn   String?  @map("secondary_cta_text_bn") @db.VarChar(100)
  goalAmount           Decimal? @map("goal_amount") @db.Decimal(14, 2)
  showImpactCounters   Boolean  @default(true) @map("show_impact_counters")
  showPurposeCards     Boolean  @default(true) @map("show_purpose_cards")
  showCampaigns        Boolean  @default(true) @map("show_campaigns")
  showImpactStories    Boolean  @default(true) @map("show_impact_stories")
  showDonorWall        Boolean  @default(true) @map("show_donor_wall")
  showTransparency     Boolean  @default(true) @map("show_transparency")
  showQrSection        Boolean  @default(true) @map("show_qr_section")
  faqJson              Json?    @map("faq_json")
  seoTitle             String?  @map("seo_title") @db.VarChar(255)
  seoDescription       String?  @map("seo_description") @db.Text
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("donation_page_settings")
}
