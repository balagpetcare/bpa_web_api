// ─── Campaign Core ─────────────────────────────────────────────────

model Campaign {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                  String         @unique @db.VarChar(280)
  title                 String         @db.VarChar(255)
  description           String?        @db.Text
  campaignType          CampaignType   @map("campaign_type")
  status                CampaignStatus @default(draft)
  startDate             DateTime       @map("start_date") @db.Timestamptz
  endDate               DateTime       @map("end_date") @db.Timestamptz
  registrationOpenAt    DateTime?      @map("registration_open_at") @db.Timestamptz
  registrationCloseAt   DateTime?      @map("registration_close_at") @db.Timestamptz
  basePriceBdt          Decimal        @default(0) @map("base_price_bdt") @db.Decimal(10, 2)
  maxPetsPerBooking     Int            @default(10) @map("max_pets_per_booking")
  certificateTemplateId String?        @map("certificate_template_id") @db.Uuid
  coverImageId          String?        @map("cover_image_id") @db.Uuid
  metadata              Json?
  isFeatured            Boolean        @default(false) @map("is_featured")
  allowedPetTypes       String[]       @default([]) @map("allowed_pet_types")
  termsAndConditions    String?        @map("terms_and_conditions") @db.Text
  faq                   Json?
  createdById           String         @map("created_by_id") @db.Uuid
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  createdBy           User                   @relation("CampaignCreatedBy", fields: [createdById], references: [id])
  certificateTemplate CertificateTemplate?   @relation(fields: [certificateTemplateId], references: [id])
  coverImage          MediaFile?             @relation("CampaignCover", fields: [coverImageId], references: [id])
  media               CampaignMedia[]
  sessions            CampaignSession[]
