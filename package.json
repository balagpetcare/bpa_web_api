{
  "name": "bpa-backend-api",
  "version": "1.0.0",
  "description": "Bangladesh Pet Association — Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node -r dotenv/config ./node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only src/server.ts",
    "build": "node -r dotenv/config ./node_modules/typescript/bin/tsc",
    "start": "node -r dotenv/config dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "seed:root-admin": "ts-node -r dotenv/config prisma/seed-root-admin.ts",
    "seed:hero": "ts-node -r dotenv/config prisma/seed-hero.ts",
    "db:studio": "prisma studio",
    "storage:test": "ts-node -r dotenv/config scripts/test_storage.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/lib-storage": "^3.1068.0",
    "@prisma/client": "^5.14.0",
    "@smithy/node-http-handler": "^4.8.0",
    "@types/express-rate-limit": "^5.1.3",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "eps-gateway-nodejs": "^1.0.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.19.1",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
