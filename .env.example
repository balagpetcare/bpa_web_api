# ─── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# ─── Root Admin (used by: npm run seed:root-admin) ──────────────
ROOT_ADMIN_NAME="BPA Root Admin"
ROOT_ADMIN_EMAIL=admin@bpa.org
ROOT_ADMIN_PASSWORD=ChangeThisStrongPassword123!
ROOT_ADMIN_ROLE=super_admin

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/bpa_db

# ─── JWT ────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Rate Limiting ──────────────────────────────────────────────
PUBLIC_REGISTRATION_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_REGISTRATION_RATE_LIMIT_MAX=50

# ─── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Bcrypt ─────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Email Gateway ──────────────────────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=no-reply@example.com
EMAIL_PASS=email_password
EMAIL_FROM="Bangladesh Pet Association <no-reply@example.com>"

# ─── SMS Gateway ────────────────────────────────────────────────
SMS_API_URL=https://sms-gateway.example.com/api/send
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=BPA

# ─── EPS Payment Gateway ────────────────────────────────────────
# Set EPS_ENABLED=true and PAYMENT_CHANNEL_MODE=EPS to activate online payments.
# Leave EPS_ENABLED=false to use manual/support fallback mode (default for new installs).
#
# EPS_ENV=demo        → sandbox endpoints  (sandbox-pgapi.eps.com.bd) — for testing
# EPS_ENV=production  → live endpoints     (pgapi.eps.com.bd)         — for go-live
#
EPS_ENABLED=false
EPS_ENV=demo
PAYMENT_CHANNEL_MODE=MANUAL
EPS_MOCK_MODE=false
EPS_MERCHANT_ID=
EPS_STORE_ID=
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=

# Comma-separated list of EPS callback server IPs to allowlist (production only).
# Leave empty in development — all IPs are accepted when the list is blank.
EPS_CALLBACK_IPS=

# ─── Media / File Storage ────────────────────────────────────────
# STORAGE_DRIVER=local  → write files to ./uploads/ (default for development)
# STORAGE_DRIVER=s3     → upload to S3-compatible provider (MinIO, AWS, DO Spaces, etc.)
STORAGE_DRIVER=local

# Required when STORAGE_DRIVER=s3
# MinIO (local dev):
#   S3_ENDPOINT=http://127.0.0.1:9000
#   S3_FORCE_PATH_STYLE=true
# AWS S3 (production):
#   S3_ENDPOINT=   (leave blank — SDK auto-resolves)
#   S3_FORCE_PATH_STYLE=false
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=bpa-media
S3_ACCESS_KEY_ID=your_minio_access_key
S3_SECRET_ACCESS_KEY=your_minio_secret_key
S3_FORCE_PATH_STYLE=true

# Public base URL used when building media URLs returned to clients.
# MinIO (local):  http://127.0.0.1:9000/bpa-media
# AWS S3:         https://bpa-media.s3.amazonaws.com
# DO Spaces:      https://bpa-media.nyc3.digitaloceanspaces.com
# Leave unset when STORAGE_DRIVER=local — falls back to BACKEND_URL/uploads
MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:9000/bpa-media

# ─── Auth & Social ──────────────────────────────────────────────
AUTH_COOKIE_NAME=bpa_user_session
AUTH_JWT_SECRET=replace_with_min_32_chars_secret
AUTH_JWT_EXPIRES_IN=7d
AUTH_PUBLIC_WEB_URL=https://bangladeshpetassociation.com
AUTH_ADMIN_WEB_URL=https://admin.bangladeshpetassociation.com
AUTH_API_URL=https://api.bangladeshpetassociation.com

# OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/facebook/callback

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/instagram/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=https://api.bangladeshpetassociation.com/api/v1/auth/oauth/twitter/callback

# OTP Settings
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
