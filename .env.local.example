# BPA Backend API (server-side only — never expose to browser)
BACKEND_API_URL=http://localhost:4000/api/v1

# BPA Backend API (client-side — used in api.ts BASE_URL)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# NextAuth
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change_me_to_at_least_32_random_chars

# Media base URL for image src paths
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:4000

# Public frontend base URL used for care-card verification links
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
